<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RCMM.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RCMM">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>

                <!-- Single dark theme — RCMM forces dark mode in MainWindow -->
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="AppBgColor">#0b0b0d</Color>
                    <Color x:Key="AppSurfaceColor">#141418</Color>
                    <Color x:Key="AppSurfaceHoverColor">#1f1f25</Color>
                    <Color x:Key="AppBorderColor">#26262c</Color>
                    <Color x:Key="AppBorderStrongColor">#353540</Color>
                    <Color x:Key="AppTextColor">#f1f1f3</Color>
                    <Color x:Key="AppTextMutedColor">#8a8a93</Color>
                    <Color x:Key="AppTextDimColor">#555560</Color>
                    <Color x:Key="AppAccentColor">#d4ff3a</Color>
                    <Color x:Key="AppAccentDimColor">#92bd4c</Color>
                    <Color x:Key="AppDangerColor">#ff6b6b</Color>

                    <SolidColorBrush x:Key="WindowBackground"      Color="{StaticResource AppBgColor}"/>
                    <SolidColorBrush x:Key="FooterBackground"      Color="#101013"/>
                    <SolidColorBrush x:Key="AppSurface"             Color="{StaticResource AppSurfaceColor}"/>
                    <SolidColorBrush x:Key="AppSurfaceHover"        Color="{StaticResource AppSurfaceHoverColor}"/>
                    <SolidColorBrush x:Key="AppBorder"              Color="{StaticResource AppBorderColor}"/>
                    <SolidColorBrush x:Key="AppBorderStrong"        Color="{StaticResource AppBorderStrongColor}"/>
                    <SolidColorBrush x:Key="AppText"                Color="{StaticResource AppTextColor}"/>
                    <SolidColorBrush x:Key="AppTextMuted"           Color="{StaticResource AppTextMutedColor}"/>
                    <SolidColorBrush x:Key="AppTextDim"             Color="{StaticResource AppTextDimColor}"/>
                    <SolidColorBrush x:Key="AppAccent"              Color="{StaticResource AppAccentColor}"/>
                    <SolidColorBrush x:Key="AppAccentDim"           Color="{StaticResource AppAccentDimColor}"/>
                    <SolidColorBrush x:Key="AppAccentGlow"          Color="#d4ff3a" Opacity="0.18"/>
                    <SolidColorBrush x:Key="AppAccentGlowSoft"      Color="#d4ff3a" Opacity="0.08"/>
                    <SolidColorBrush x:Key="AppAccentHalo"          Color="#d4ff3a" Opacity="0.22"/>
                    <SolidColorBrush x:Key="AppCool"                Color="#5ec8ff"/>
                    <SolidColorBrush x:Key="AppCoolDim"             Color="#3a8ec0"/>
                    <SolidColorBrush x:Key="AppNeutral"             Color="#3f3f4a"/>
                    <SolidColorBrush x:Key="AppNeutralLight"        Color="#7a7a85"/>

                    <!-- Override the WinUI accent brushes so any control using SystemAccent picks up lime -->
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="{StaticResource AppAccentColor}"/>
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="{StaticResource AppAccentColor}" Opacity="0.92"/>
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="{StaticResource AppAccentColor}" Opacity="0.84"/>
                    <SolidColorBrush x:Key="AccentFillColorDisabledBrush"         Color="#3a3a40"/>
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush"    Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush"  Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush"   Color="#6a6a72"/>

                    <SolidColorBrush x:Key="ToggleSwitchFillOn"                   Color="{StaticResource AppAccentColor}"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver"        Color="{StaticResource AppAccentColor}" Opacity="0.92"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed"            Color="{StaticResource AppAccentColor}" Opacity="0.84"/>
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOn"                 Color="{StaticResource AppAccentColor}"/>
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver"      Color="{StaticResource AppAccentColor}"/>
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed"          Color="{StaticResource AppAccentColor}"/>
                    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn"               Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver"    Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed"        Color="#0a0a0a"/>

                    <!-- ListViewItem hover/selected states use accent by default — neutralise -->
                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver"    Color="{StaticResource AppSurfaceHoverColor}"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected"       Color="{StaticResource AppSurfaceHoverColor}"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{StaticResource AppSurfaceHoverColor}"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed"     Color="{StaticResource AppSurfaceHoverColor}"/>
                    <SolidColorBrush x:Key="ListViewItemSelectedBackground"       Color="{StaticResource AppSurfaceHoverColor}"/>
                    <SolidColorBrush x:Key="ListViewItemForegroundSelected"       Color="{StaticResource AppTextColor}"/>
                </ResourceDictionary>

                <!-- Light fallback (we never enter this) but keep the keys defined -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WindowBackground" Color="#0b0b0d"/>
                    <SolidColorBrush x:Key="FooterBackground" Color="#101013"/>
                    <SolidColorBrush x:Key="AppSurface"        Color="#141418"/>
                    <SolidColorBrush x:Key="AppSurfaceHover"   Color="#1f1f25"/>
                    <SolidColorBrush x:Key="AppBorder"         Color="#26262c"/>
                    <SolidColorBrush x:Key="AppBorderStrong"   Color="#353540"/>
                    <SolidColorBrush x:Key="AppText"           Color="#f1f1f3"/>
                    <SolidColorBrush x:Key="AppTextMuted"      Color="#8a8a93"/>
                    <SolidColorBrush x:Key="AppTextDim"        Color="#555560"/>
                    <SolidColorBrush x:Key="AppAccent"         Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="AppAccentDim"      Color="#92bd4c"/>
                    <SolidColorBrush x:Key="AppAccentGlow"     Color="#d4ff3a" Opacity="0.18"/>
                    <SolidColorBrush x:Key="AppAccentGlowSoft" Color="#d4ff3a" Opacity="0.08"/>
                    <SolidColorBrush x:Key="AppAccentHalo"     Color="#d4ff3a" Opacity="0.22"/>
                    <SolidColorBrush x:Key="AppCool"           Color="#5ec8ff"/>
                    <SolidColorBrush x:Key="AppCoolDim"        Color="#3a8ec0"/>
                    <SolidColorBrush x:Key="AppNeutral"        Color="#3f3f4a"/>
                    <SolidColorBrush x:Key="AppNeutralLight"   Color="#7a7a85"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WindowBackground" Color="#0b0b0d"/>
                    <SolidColorBrush x:Key="FooterBackground" Color="#101013"/>
                    <SolidColorBrush x:Key="AppSurface"        Color="#141418"/>
                    <SolidColorBrush x:Key="AppSurfaceHover"   Color="#1f1f25"/>
                    <SolidColorBrush x:Key="AppBorder"         Color="#26262c"/>
                    <SolidColorBrush x:Key="AppBorderStrong"   Color="#353540"/>
                    <SolidColorBrush x:Key="AppText"           Color="#f1f1f3"/>
                    <SolidColorBrush x:Key="AppTextMuted"      Color="#8a8a93"/>
                    <SolidColorBrush x:Key="AppTextDim"        Color="#555560"/>
                    <SolidColorBrush x:Key="AppAccent"         Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="AppAccentDim"      Color="#92bd4c"/>
                    <SolidColorBrush x:Key="AppAccentGlow"     Color="#d4ff3a" Opacity="0.18"/>
                    <SolidColorBrush x:Key="AppAccentGlowSoft" Color="#d4ff3a" Opacity="0.08"/>
                    <SolidColorBrush x:Key="AppAccentHalo"     Color="#d4ff3a" Opacity="0.22"/>
                    <SolidColorBrush x:Key="AppCool"           Color="#5ec8ff"/>
                    <SolidColorBrush x:Key="AppCoolDim"        Color="#3a8ec0"/>
                    <SolidColorBrush x:Key="AppNeutral"        Color="#3f3f4a"/>
                    <SolidColorBrush x:Key="AppNeutralLight"   Color="#7a7a85"/>

                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#d4ff3a" Opacity="0.92"/>
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#d4ff3a" Opacity="0.84"/>
                    <SolidColorBrush x:Key="AccentFillColorDisabledBrush"  Color="#3a3a40"/>
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush"   Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush"  Color="#6a6a72"/>

                    <SolidColorBrush x:Key="ToggleSwitchFillOn"                Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver"     Color="#d4ff3a" Opacity="0.92"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed"         Color="#d4ff3a" Opacity="0.84"/>
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOn"              Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver"   Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed"       Color="#d4ff3a"/>
                    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn"            Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#0a0a0a"/>
                    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed"     Color="#0a0a0a"/>

                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#1f1f25"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected"    Color="#1f1f25"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#1f1f25"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed"     Color="#1f1f25"/>
                    <SolidColorBrush x:Key="ListViewItemSelectedBackground"    Color="#1f1f25"/>
                    <SolidColorBrush x:Key="ListViewItemForegroundSelected"    Color="#f1f1f3"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>

            <!-- Reusable card style with hover glow -->
            <Style x:Key="NavCard" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AppSurface}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource AppBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Padding" Value="28"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="MinHeight" Value="260"/>
                <Setter Property="Foreground" Value="{ThemeResource AppText}"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid">
                                <!-- Base surface, always visible -->
                                <Border x:Name="BaseBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}"/>
                                <!-- Soft lime radial glow anchored at top, fades in on hover -->
                                <Border x:Name="GlowOverlay"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        IsHitTestVisible="False"
                                        Opacity="0">
                                    <Border.Background>
                                        <RadialGradientBrush Center="0.5,0.05" GradientOrigin="0.5,0.05"
                                                             RadiusX="0.65" RadiusY="0.45">
                                            <GradientStop Color="#3dd4ff3a" Offset="0"/>
                                            <GradientStop Color="#14d4ff3a" Offset="0.5"/>
                                            <GradientStop Color="#00d4ff3a" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Lime border outline, fades in on hover -->
                                <Border x:Name="HoverOutline"
                                        BorderBrush="{ThemeResource AppAccentDim}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        IsHitTestVisible="False"
                                        Opacity="0"/>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Padding="{TemplateBinding Padding}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Foreground="{TemplateBinding Foreground}"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowOverlay"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.22"/>
                                                <DoubleAnimation Storyboard.TargetName="HoverOutline"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.22"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowOverlay"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.7" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetName="HoverOutline"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Lime primary button (Apply) with glow on hover -->
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AppAccent}"/>
                <Setter Property="Foreground" Value="#0a0a0a"/>
                <Setter Property="BorderBrush" Value="{ThemeResource AppAccent}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root">
                                <!-- Halo glow behind the button -->
                                <Border x:Name="Halo" CornerRadius="14" Margin="-6"
                                        Background="{ThemeResource AppAccentHalo}"
                                        Opacity="0.45" IsHitTestVisible="False"/>
                                <Border x:Name="Body"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <ContentPresenter
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        Padding="{TemplateBinding Padding}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{TemplateBinding Foreground}"
                                        FontWeight="{TemplateBinding FontWeight}"/>
                                </Border>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Halo"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Body"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.85" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Halo"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0"/>
                                                <DoubleAnimation Storyboard.TargetName="Body"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.35" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pill-shaped category chip. Bare-bones template (no halo, no
                 focus visual, no Mica fallback) so the active chip just shows
                 its accent fill without bleeding any default WinUI button
                 glow. Background / Foreground / BorderBrush are driven from
                 code-behind to flip active/inactive state. -->
            <Style x:Key="ChipButton" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AppSurface}"/>
                <Setter Property="Foreground" Value="{ThemeResource AppText}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource AppBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="18,0"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Body"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}"
                                    FontSize="{TemplateBinding FontSize}"
                                    FontWeight="{TemplateBinding FontWeight}"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Body"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.85" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Body"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.7" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Body"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.35" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Title-bar icon button: small, transparent, lime-on-hover -->
            <Style x:Key="TitleBarIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Foreground" Value="{ThemeResource AppTextMuted}"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root">
                                <Border x:Name="HoverBg" Background="{ThemeResource AppSurfaceHover}"
                                        CornerRadius="{TemplateBinding CornerRadius}" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="{TemplateBinding Foreground}"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.7" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.35" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter"/>
            <local:ObjectToImageSourceConverter x:Key="ObjectToImageSourceConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
