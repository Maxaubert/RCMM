<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RCMM.Views.ConvertWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="{ThemeResource WindowBackground}" Padding="24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="FileText" Grid.Row="0"
                   Foreground="{ThemeResource AppText}" FontSize="16" FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis"/>
        <TextBlock x:Name="PromptText" Grid.Row="1"
                   Foreground="{ThemeResource AppTextMuted}" FontSize="13"/>
        <StackPanel x:Name="TargetsPanel" Grid.Row="2" Orientation="Horizontal" Spacing="8"/>
        <TextBlock x:Name="StatusText" Grid.Row="3"
                   Foreground="{ThemeResource AppTextMuted}" FontSize="12.5" TextWrapping="Wrap"/>
        <Button x:Name="InstallButton" Grid.Row="4" VerticalAlignment="Top"
                Visibility="Collapsed" Click="Install_Click"
                Style="{StaticResource SurfaceButton}"/>
    </Grid>
</Window>
