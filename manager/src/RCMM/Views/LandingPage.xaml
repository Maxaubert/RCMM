<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RCMM.Views.LandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="48,40,48,40" RowSpacing="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Heading -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="10" HorizontalAlignment="Left">
                <TextBlock x:Name="HeadingTitle" Text="What would you like to do?" FontSize="38" FontWeight="Medium"
                           Foreground="{ThemeResource AppText}" CharacterSpacing="-15" HorizontalAlignment="Left"/>
                <TextBlock Text="Customize the right-click menu in Windows Explorer."
                           Foreground="{ThemeResource AppTextMuted}" FontSize="13" TextWrapping="Wrap" MaxWidth="540"
                           HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="12">
                <!-- Donut chart -->
                <Grid Width="120" Height="120" HorizontalAlignment="Right">
                    <Path x:Name="WinArcPath" Fill="#e84a4a"/>
                    <Path x:Name="AppArcPath" Fill="#ffea3a"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="-2">
                        <TextBlock x:Name="TotalNumber" FontSize="26" FontWeight="Medium"
                                   FontFamily="Consolas, Cascadia Code, monospace"
                                   Foreground="{ThemeResource AppText}"
                                   HorizontalAlignment="Center" LineHeight="28"/>
                        <TextBlock Text="ENTRIES" FontFamily="Consolas, Cascadia Code, monospace"
                                   FontSize="9" Foreground="{ThemeResource AppTextDim}"
                                   HorizontalAlignment="Center" CharacterSpacing="200"/>
                    </StackPanel>
                </Grid>

                <!-- Legend -->
                <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="#ffea3a" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AppCountLabel" FontFamily="Consolas, Cascadia Code, monospace"
                                   FontSize="11" Foreground="{ThemeResource AppTextMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="APP" FontFamily="Consolas, Cascadia Code, monospace"
                                   FontSize="10" Foreground="{ThemeResource AppTextDim}"
                                   CharacterSpacing="150" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="#e84a4a" VerticalAlignment="Center"/>
                        <TextBlock x:Name="WinCountLabel" FontFamily="Consolas, Cascadia Code, monospace"
                                   FontSize="11" Foreground="{ThemeResource AppTextMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="WIN" FontFamily="Consolas, Cascadia Code, monospace"
                                   FontSize="10" Foreground="{ThemeResource AppTextDim}"
                                   CharacterSpacing="150" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Card grid -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Show / hide card -->
            <Button Grid.Column="0" Style="{StaticResource NavCard}" Click="ShowHide_Click">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Width="56" Height="56" HorizontalAlignment="Left">
                        <!-- Lime glow halo behind the icon, always visible -->
                        <Border Width="56" Height="56" CornerRadius="10"
                                Background="{ThemeResource AppAccentGlowSoft}"/>
                        <Border Width="44" Height="44" CornerRadius="6"
                                Background="{ThemeResource AppSurfaceHover}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BorderBrush="{ThemeResource AppAccentDim}" BorderThickness="1">
                            <FontIcon Glyph="&#xE7B3;" FontSize="20" Foreground="{ThemeResource AppAccent}"/>
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="Show / hide" FontSize="22" FontWeight="Medium"
                               Foreground="{ThemeResource AppText}"/>
                    <TextBlock Grid.Row="2" TextWrapping="Wrap"
                               Text="Toggle visibility of entries already in your right-click menu."
                               Foreground="{ThemeResource AppTextMuted}" FontSize="13"/>
                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="{ThemeResource AppBorder}" BorderThickness="0,1,0,0"
                                Padding="0,14,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock x:Name="ShowHideCount" FontSize="24" FontWeight="Medium"
                                           FontFamily="Consolas, Cascadia Code, monospace"
                                           Foreground="{ThemeResource AppAccent}"/>
                                <TextBlock Text="ENTRIES" FontFamily="Consolas, Cascadia Code, monospace"
                                           FontSize="11" Foreground="{ThemeResource AppTextDim}"
                                           VerticalAlignment="Center" CharacterSpacing="100"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Button>

            <!-- Add to menu -->
            <Button Grid.Column="1" Style="{StaticResource NavCard}" Click="AddToMenu_Click">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Width="56" Height="56" HorizontalAlignment="Left">
                        <Border Width="56" Height="56" CornerRadius="10"
                                Background="{ThemeResource AppAccentGlowSoft}"/>
                        <Border Width="44" Height="44" CornerRadius="6"
                                Background="{ThemeResource AppSurfaceHover}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BorderBrush="{ThemeResource AppAccentDim}" BorderThickness="1">
                            <FontIcon Glyph="&#xE710;" FontSize="20" Foreground="{ThemeResource AppAccent}"/>
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="Add to menu" FontSize="22" FontWeight="Medium"
                               Foreground="{ThemeResource AppText}"/>
                    <TextBlock Grid.Row="2" TextWrapping="Wrap"
                               Text="Add entries from the template catalogue: group into submenus, reorder, rename, and pick icons."
                               Foreground="{ThemeResource AppTextMuted}" FontSize="13"/>
                    <Border Grid.Row="3" BorderBrush="{ThemeResource AppBorder}" BorderThickness="0,1,0,0"
                            Padding="0,14,0,0" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="AddCountLabel" FontSize="24" FontWeight="Medium"
                                       FontFamily="Consolas, Cascadia Code, monospace"
                                       Foreground="{ThemeResource AppAccent}"/>
                            <TextBlock Text="ENTRIES" FontFamily="Consolas, Cascadia Code, monospace"
                                       FontSize="11" Foreground="{ThemeResource AppTextDim}"
                                       VerticalAlignment="Center" CharacterSpacing="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>
