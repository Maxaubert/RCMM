<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RCMM.Views.AddPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RCMM.Views"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    PointerMoved="Page_PointerMoved"
    PointerReleased="Page_PointerReleased"
    PointerCaptureLost="Page_PointerCaptureLost">

    <Grid Padding="48,28,48,28" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Heading -->
        <Grid Grid.Row="0" ColumnSpacing="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Add to menu" FontSize="38" FontWeight="Normal"
                       Foreground="{ThemeResource AppText}" CharacterSpacing="-15"
                       VerticalAlignment="Bottom"/>
            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" Padding="0,0,0,6"
                       Foreground="{ThemeResource AppTextMuted}" FontSize="13"
                       TextWrapping="Wrap" MaxWidth="720"
                       Text="Add your own entries to the (classic) right-click menu. Pick a template or write a custom command. Group entries into folders that render as submenus. Drag to reorder, or drop onto a folder to move into it."/>
        </Grid>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
            <Button x:Name="NewEntryButton" Content="+ New entry" Click="NewEntry_Click"
                    Background="{ThemeResource AppSurface}" BorderBrush="{ThemeResource AppBorder}"
                    Foreground="{ThemeResource AppText}" CornerRadius="8" Padding="14,8"/>
            <Button x:Name="NewFolderButton" Content="+ New folder" Click="NewFolder_Click"
                    Background="{ThemeResource AppSurface}" BorderBrush="{ThemeResource AppBorder}"
                    Foreground="{ThemeResource AppText}" CornerRadius="8" Padding="14,8"/>
            <Button x:Name="TemplatesButton" Content="Browse templates" Click="Templates_Click"
                    Background="{ThemeResource AppSurface}" BorderBrush="{ThemeResource AppBorder}"
                    Foreground="{ThemeResource AppText}" CornerRadius="8" Padding="14,8"/>
        </StackPanel>

        <!-- Master grid: 2-col by default, 3-col when a folder is selected -->
        <Grid Grid.Row="2" x:Name="MasterGrid" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol"   Width="340"/>
                <ColumnDefinition x:Name="MiddleCol" Width="0"/>
                <ColumnDefinition x:Name="RightCol"  Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANE -->
            <Border Grid.Column="0"
                    Background="{ThemeResource AppSurface}"
                    BorderBrush="{ThemeResource AppBorder}"
                    BorderThickness="1" CornerRadius="10">
                <ListView x:Name="LeftList"
                          SelectionMode="Single"
                          SelectionChanged="LeftList_SelectionChanged"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="34"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <!-- AllowDrop is set on the ListView itself; setting it
                                 on individual ListViewItems intercepts drops before
                                 the framework reorder logic, so DragItemsCompleted
                                 never fires. -->
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <!-- Row visuals are painted from code-behind
                                 (ApplyLeftRowVisuals) — see AddPage.xaml.cs. We
                                 dropped {Binding} + INPC because container recycling
                                 under WinUI 3 virtualization left stale binding
                                 subscriptions, which painted the selection bar on
                                 the wrong rows. -->
                            <Grid x:Name="RowRoot" Padding="14,7,12,7" ColumnSpacing="2"
                                  Loaded="RowRoot_Loaded"
                                  DataContextChanged="RowRoot_DataContextChanged">
                                <Grid.ColumnDefinitions>
                                    <!-- Indent spacer driven from code-behind via Margin -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Twist (folders) — always reserved width -->
                                    <ColumnDefinition Width="18"/>
                                    <!-- Icon (optional) -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Label -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- Badge -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Grip on hover -->
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selection bar shown via a left-side rectangle, only when selected.
                                     ListView's own selection bg is hidden by ItemContainerStyle. -->
                                <Rectangle x:Name="SelBar" Grid.Column="0" Grid.ColumnSpan="6"
                                           Width="3" HorizontalAlignment="Left"
                                           Fill="{ThemeResource AppAccent}"
                                           Visibility="Collapsed"/>

                                <!-- Drop indicator lines (top/bottom) for reorder, row fill for drop-into -->
                                <Rectangle x:Name="DropTop" Grid.Column="0" Grid.ColumnSpan="6"
                                           Height="2" VerticalAlignment="Top"
                                           Fill="{ThemeResource AppAccent}" Visibility="Collapsed"/>
                                <Rectangle x:Name="DropBottom" Grid.Column="0" Grid.ColumnSpan="6"
                                           Height="2" VerticalAlignment="Bottom"
                                           Fill="{ThemeResource AppAccent}" Visibility="Collapsed"/>
                                <Rectangle x:Name="DropIntoFill" Grid.Column="0" Grid.ColumnSpan="6"
                                           Fill="{ThemeResource AppAccentGlow}"
                                           Stroke="{ThemeResource AppAccent}" StrokeThickness="1"
                                           RadiusX="3" RadiusY="3"
                                           Visibility="Collapsed"/>

                                <Border x:Name="IndentSpacer" Grid.Column="0" Width="0"/>

                                <TextBlock x:Name="Twist" Grid.Column="1"
                                           Foreground="{ThemeResource AppTextMuted}"
                                           FontSize="10" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Tapped="Twist_Tapped"/>

                                <Border
                                    x:Name="IconHost" Grid.Column="2"
                                    Width="16" Height="16"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"/>

                                <TextBlock x:Name="Label" Grid.Column="3"
                                           Foreground="{ThemeResource AppText}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="Badge" Grid.Column="4"
                                           Foreground="{ThemeResource AppTextDim}"
                                           FontSize="11" Margin="8,0,8,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>

                                <!-- Drag handle. Custom DragHandle subclass flips the
                                     cursor to a 4-way move on hover; the pointer
                                     handlers below drive a manual reorder of the row
                                     collection. We don't use WinUI's CanDragItems /
                                     CanReorderItems because they're broken in
                                     unpackaged WinUI 3 apps — the OS-level drag
                                     infrastructure (IDropTargetHelper et al.) isn't
                                     COM-registered, so the framework's drag never
                                     produces drop events. -->
                                <local:DragHandle x:Name="GripHost" Grid.Column="5"
                                                  Background="Transparent"
                                                  Padding="8,0,4,0" MinWidth="28"
                                                  VerticalAlignment="Stretch"
                                                  ManipulationMode="None"
                                                  PointerPressed="GripHost_PointerPressed">
                                    <TextBlock x:Name="Grip"
                                               Text="&#xE76F;" FontFamily="Segoe Fluent Icons"
                                               Foreground="{ThemeResource AppTextDim}"
                                               FontSize="12" Opacity="0.55"
                                               VerticalAlignment="Center"/>
                                </local:DragHandle>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- MIDDLE PANE (folder contents) — only visible when a folder is selected -->
            <Border x:Name="MiddlePane" Grid.Column="1"
                    Background="{ThemeResource AppSurface}"
                    BorderBrush="{ThemeResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Visibility="Collapsed">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="14,12,14,10" ColumnSpacing="10"
                          BorderBrush="{ThemeResource AppBorder}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BackButton" Grid.Column="0" Padding="6"
                                MinWidth="0" MinHeight="0"
                                Background="{ThemeResource AppSurfaceHover}"
                                BorderBrush="{ThemeResource AppBorder}"
                                Foreground="{ThemeResource AppText}"
                                CornerRadius="5" Click="Back_Click"
                                IsEnabled="False">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                        </Button>
                        <StackPanel Grid.Column="1" x:Name="CrumbStack"
                                    Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="MiddleCount"
                                   Foreground="{ThemeResource AppTextMuted}"
                                   FontSize="11.5" VerticalAlignment="Center"/>
                    </Grid>

                    <ListView Grid.Row="1" x:Name="MiddleList"
                              SelectionMode="Single"
                              SelectionChanged="MiddleList_SelectionChanged"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="50"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="MidRowRoot" Padding="14,9,14,9" ColumnSpacing="10"
                                      Loaded="MidRowRoot_Loaded"
                                      DataContextChanged="MidRowRoot_DataContextChanged">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Rectangle x:Name="MidDropTop" Grid.Column="0" Grid.ColumnSpan="4"
                                               Height="2" VerticalAlignment="Top"
                                               Fill="{ThemeResource AppAccent}" Visibility="Collapsed"/>
                                    <Rectangle x:Name="MidDropBottom" Grid.Column="0" Grid.ColumnSpan="4"
                                               Height="2" VerticalAlignment="Bottom"
                                               Fill="{ThemeResource AppAccent}" Visibility="Collapsed"/>
                                    <Rectangle x:Name="MidDropIntoFill" Grid.Column="0" Grid.ColumnSpan="4"
                                               Fill="{ThemeResource AppAccentGlow}"
                                               Stroke="{ThemeResource AppAccent}" StrokeThickness="1"
                                               RadiusX="3" RadiusY="3"
                                               Visibility="Collapsed"/>

                                    <TextBlock x:Name="MidOrder" Grid.Column="0"
                                               Foreground="{ThemeResource AppTextDim}" FontSize="11"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" Margin="0,0,4,0"/>

                                    <Border
                                        x:Name="MidIconHost" Grid.Column="1"
                                        Width="20" Height="20"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"/>

                                    <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="2"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="MidLabel"
                                                   Foreground="{ThemeResource AppText}"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="MidSub"
                                                   Foreground="{ThemeResource AppTextMuted}"
                                                   FontSize="11.5"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>

                                    <local:DragHandle x:Name="MidGripHost" Grid.Column="3"
                                                      Background="Transparent"
                                                      Padding="10,0,6,0" MinWidth="32"
                                                      VerticalAlignment="Stretch"
                                                      ManipulationMode="None"
                                                      PointerPressed="GripHost_PointerPressed">
                                        <TextBlock x:Name="MidGrip"
                                                   Text="&#xE76F;" FontFamily="Segoe Fluent Icons"
                                                   Foreground="{ThemeResource AppTextDim}"
                                                   FontSize="12" Opacity="0.55"
                                                   VerticalAlignment="Center"/>
                                    </local:DragHandle>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- RIGHT PANE: editor -->
            <Border Grid.Column="2"
                    Background="{ThemeResource AppSurface}"
                    BorderBrush="{ThemeResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="22">
                <ScrollViewer>
                    <Grid>
                        <!-- Empty state -->
                        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Spacing="6"
                                    Visibility="Visible">
                            <TextBlock Text="Select something" Foreground="{ThemeResource AppText}"
                                       FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pick an entry or folder on the left to edit it."
                                       Foreground="{ThemeResource AppTextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Editor -->
                        <StackPanel x:Name="EditorPanel" Spacing="12" Visibility="Collapsed">
                            <TextBlock x:Name="EditorTitle" Text="Edit entry"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource AppText}"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Name" Foreground="{ThemeResource AppTextMuted}" FontSize="12"/>
                                <TextBox x:Name="NameBox" LostFocus="Field_Changed" TextChanged="NameBox_TextChanged"/>
                            </StackPanel>

                            <StackPanel x:Name="CommandRow" Spacing="4">
                                <TextBlock Text="Command" Foreground="{ThemeResource AppTextMuted}" FontSize="12"/>
                                <TextBox x:Name="CommandBox" FontFamily="Cascadia Code, Consolas, Courier New" LostFocus="Field_Changed"/>
                            </StackPanel>

                            <Grid x:Name="WorkRunRow" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Working dir" Foreground="{ThemeResource AppTextMuted}" FontSize="12"/>
                                    <TextBox x:Name="WorkingDirBox" FontFamily="Cascadia Code, Consolas, Courier New" LostFocus="Field_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Run mode" Foreground="{ThemeResource AppTextMuted}" FontSize="12"/>
                                    <ComboBox x:Name="RunModeBox" HorizontalAlignment="Stretch" SelectionChanged="Field_SelectionChanged"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="ScopeRow" Spacing="4">
                                <TextBlock>
                                    <Run Text="Scope"/><Run Text="  (where the entry appears)" Foreground="{ThemeResource AppTextDim}" FontSize="11"/>
                                </TextBlock>
                                <ComboBox x:Name="ScopeBox" HorizontalAlignment="Stretch" SelectionChanged="Field_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel x:Name="FileTypesRow" Spacing="4">
                                <TextBlock>
                                    <Run Text="File types"/><Run Text="  (comma-separated, when Scope = File)" Foreground="{ThemeResource AppTextDim}" FontSize="11"/>
                                </TextBlock>
                                <TextBox x:Name="FileTypesBox" FontFamily="Cascadia Code, Consolas, Courier New" LostFocus="Field_Changed"/>
                            </StackPanel>

                            <StackPanel x:Name="FolderRow" Spacing="4">
                                <TextBlock>
                                    <Run Text="Folder"/><Run Text="  (parent submenu)" Foreground="{ThemeResource AppTextDim}" FontSize="11"/>
                                </TextBlock>
                                <ComboBox x:Name="FolderBox" HorizontalAlignment="Stretch" SelectionChanged="Field_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel x:Name="ParentFolderRow" Spacing="4" Visibility="Collapsed">
                                <TextBlock>
                                    <Run Text="Parent folder"/><Run Text="  (max 3 levels deep)" Foreground="{ThemeResource AppTextDim}" FontSize="11"/>
                                </TextBlock>
                                <ComboBox x:Name="ParentFolderBox" HorizontalAlignment="Stretch" SelectionChanged="Field_SelectionChanged"/>
                            </StackPanel>

                            <!-- Icon picker widget -->
                            <StackPanel x:Name="IconRow" Spacing="4">
                                <TextBlock Text="Icon" Foreground="{ThemeResource AppTextMuted}" FontSize="12"/>
                                <Border Background="{ThemeResource AppSurfaceHover}"
                                        BorderBrush="{ThemeResource AppBorder}" BorderThickness="1"
                                        CornerRadius="8" Padding="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="44" Height="44"
                                                Background="{ThemeResource WindowBackground}"
                                                BorderBrush="{ThemeResource AppBorder}" BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid x:Name="IconPreviewCell"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock x:Name="IconLabelText"
                                                       Foreground="{ThemeResource AppText}" FontSize="13"/>
                                            <TextBlock x:Name="IconSubText"
                                                       Foreground="{ThemeResource AppTextMuted}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Button x:Name="IconPickButton" Click="IconPick_Click"
                                                    Background="{ThemeResource WindowBackground}"
                                                    BorderBrush="{ThemeResource AppBorder}"
                                                    Foreground="{ThemeResource AppText}"
                                                    CornerRadius="6" Padding="10,5"
                                                    Content="Choose icon"/>
                                            <Button x:Name="IconClearButton" Click="IconClear_Click"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{ThemeResource AppTextMuted}"
                                                    Padding="6,5">
                                                <TextBlock Text="Clear" FontSize="11"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <StackPanel Spacing="2" Margin="0,4,0,0">
                                    <TextBlock>
                                        <Run Text="Custom path"/><Run Text="  (advanced — Windows DLL or .ico)" Foreground="{ThemeResource AppTextDim}" FontSize="11"/>
                                    </TextBlock>
                                    <TextBox x:Name="IconCustomBox" FontFamily="Cascadia Code, Consolas, Courier New" LostFocus="IconCustom_LostFocus"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="FolderInfoRow" Spacing="2" Visibility="Collapsed">
                                <TextBlock x:Name="FolderInfoText" Foreground="{ThemeResource AppTextMuted}" FontSize="11.5"/>
                            </StackPanel>

                            <Button x:Name="DeleteButton" Content="Delete" Click="Delete_Click"
                                    Margin="0,12,0,0"
                                    Background="Transparent"
                                    BorderBrush="{ThemeResource AppBorder}"
                                    Foreground="{ThemeResource AppText}"
                                    CornerRadius="8" Padding="14,8"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Drag overlay. Lives in the same Grid cell as MasterGrid so it
             paints on top of the lists. IsHitTestVisible=False so it doesn't
             swallow pointer events; the drag itself is captured on the Page. -->
        <Canvas x:Name="DragOverlay" Grid.Row="2" IsHitTestVisible="False">
            <Border x:Name="DragGhost"
                    Visibility="Collapsed"
                    Background="{ThemeResource AppSurfaceHover}"
                    BorderBrush="{ThemeResource AppAccent}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6,12,6"
                    Opacity="0.92">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border x:Name="DragGhostIconHost" Width="16" Height="16"
                            Visibility="Collapsed" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DragGhostLabel"
                               Foreground="{ThemeResource AppText}"
                               FontSize="13"/>
                </StackPanel>
            </Border>
            <Rectangle x:Name="DropIndicator"
                       Visibility="Collapsed"
                       Height="2"
                       Fill="{ThemeResource AppAccent}"
                       RadiusX="1" RadiusY="1"/>
            <!-- "Drop into folder" highlight. Visible when the cursor hovers
                 the middle of a folder row during a drag. -->
            <Border x:Name="DropIntoBorder"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource AppAccent}"
                    BorderThickness="2"
                    CornerRadius="4"
                    Background="{ThemeResource AppAccentGlow}"/>
        </Canvas>
    </Grid>
</Page>
