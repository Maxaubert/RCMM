<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RCMM.Views.TemplatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="48,28,48,40" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Browse templates" FontSize="38" FontWeight="Medium"
                       Foreground="{ThemeResource AppText}" CharacterSpacing="-15"/>
            <TextBlock Text="Pick a starting point. Adding a template creates a new editable entry on the Add page — the template itself stays unchanged."
                       Foreground="{ThemeResource AppTextMuted}" FontSize="13" TextWrapping="Wrap" MaxWidth="780"/>
        </StackPanel>

        <!-- Category chips. The pill geometry / hover behaviour comes from
             ChipButton (App.xaml). Active vs inactive Background / Foreground /
             BorderBrush are still flipped from code-behind so the single-select
             behaviour can be reflected without per-chip toggle plumbing. -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button x:Name="ChipFeatured" Tag="featured" Content="&#x2605; Featured" Click="Chip_Click" Style="{StaticResource ChipButton}"/>
            <Button x:Name="ChipDev"     Tag="dev"     Content="Dev tools"    Click="Chip_Click" Style="{StaticResource ChipButton}"/>
            <Button x:Name="ChipProject" Tag="project" Content="Open project" Click="Chip_Click" Style="{StaticResource ChipButton}"/>
            <Button x:Name="ChipShell"   Tag="shell"   Content="Shell"        Click="Chip_Click" Style="{StaticResource ChipButton}"/>
            <Button x:Name="ChipFiles"   Tag="files"   Content="Files"        Click="Chip_Click" Style="{StaticResource ChipButton}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="{ThemeResource AppSurface}"
                BorderBrush="{ThemeResource AppBorder}"
                BorderThickness="1" CornerRadius="10">
            <Grid>
                <!-- Empty state shown when a chip other than Dev tools is active. -->
                <TextBlock x:Name="EmptyState"
                           Visibility="Collapsed"
                           Text="No templates here yet."
                           Foreground="{ThemeResource AppTextMuted}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Padding="0,60"/>
                <ListView x:Name="TemplatesList"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="TemplateItem_Click">
                <!-- Whole row is the click target (no +Add button); the global
                     ListViewItemBackgroundPointerOver (App.xaml) gives the hover
                     highlight. Rounded + stretched so the highlight reads as a row. -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="6,0"/>
                        <Setter Property="Margin" Value="0,1"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.GroupStyle>
                    <GroupStyle HidesIfEmpty="True">
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Key}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource AppTextMuted}"
                                           Padding="8,14,8,6"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- Icon populated from code (TplRow_Loaded /
                             DataContextChanged) — same approach as the Add page
                             rows, since icons are code-built (lib vector or
                             extracted exe icon). -->
                        <Grid x:Name="TplRow" ColumnSpacing="12" Padding="8,10"
                              Loaded="TplRow_Loaded" DataContextChanged="TplRow_DataContextChanged">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="TplIcon" Grid.Column="0"
                                    Width="18" Height="18"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Visibility="Collapsed"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       Foreground="{ThemeResource AppText}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
