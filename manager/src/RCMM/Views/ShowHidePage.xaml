<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RCMM.Views.ShowHidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="48,28,48,40" RowSpacing="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Heading -->
        <StackPanel Grid.Row="0" Spacing="10" HorizontalAlignment="Left">
            <TextBlock Text="Show / hide" FontSize="38" FontWeight="Medium"
                       Foreground="{ThemeResource AppText}" CharacterSpacing="-15" HorizontalAlignment="Left"/>
            <TextBlock Text="Which side of the menu do you want to touch? Application-specific entries come from programs you've installed. Windows-specific entries are baked into Explorer."
                       Foreground="{ThemeResource AppTextMuted}" FontSize="13" TextWrapping="Wrap" MaxWidth="640"
                       HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Cards -->
        <Grid Grid.Row="1" ColumnSpacing="20" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Application specific -->
            <Button Grid.Column="0" Style="{StaticResource NavCard}" Click="App_Click">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Width="44" Height="44" CornerRadius="6"
                            Background="{ThemeResource AppSurfaceHover}" HorizontalAlignment="Left"
                            BorderBrush="{ThemeResource AppBorder}" BorderThickness="1">
                        <FontIcon Glyph="&#xECAA;" FontSize="20" Foreground="{ThemeResource AppTextMuted}"/>
                    </Border>
                    <TextBlock Grid.Row="1" Text="Application specific" FontSize="22" FontWeight="Medium"
                               Foreground="{ThemeResource AppText}"/>
                    <TextBlock Grid.Row="2" TextWrapping="Wrap"
                               Text="Entries added by programs you installed."
                               Foreground="{ThemeResource AppTextMuted}" FontSize="13"/>
                    <Border Grid.Row="3" BorderBrush="{ThemeResource AppBorder}" BorderThickness="0,1,0,0"
                            Padding="0,14,0,0" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="AppCount" FontSize="24" FontWeight="Medium"
                                       FontFamily="Consolas, Cascadia Code, monospace"
                                       Foreground="{ThemeResource AppAccent}"/>
                            <TextBlock Text="ENTRIES" FontFamily="Consolas, Cascadia Code, monospace"
                                       FontSize="11" Foreground="{ThemeResource AppTextDim}"
                                       VerticalAlignment="Center" CharacterSpacing="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Button>

            <!-- Windows specific -->
            <Button Grid.Column="1" Style="{StaticResource NavCard}" Click="Windows_Click">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Width="44" Height="44" CornerRadius="6"
                            Background="{ThemeResource AppSurfaceHover}" HorizontalAlignment="Left"
                            BorderBrush="{ThemeResource AppBorder}" BorderThickness="1">
                        <FontIcon Glyph="&#xE770;" FontSize="20" Foreground="{ThemeResource AppTextMuted}"/>
                    </Border>
                    <TextBlock Grid.Row="1" Text="Windows specific" FontSize="22" FontWeight="Medium"
                               Foreground="{ThemeResource AppText}"/>
                    <TextBlock Grid.Row="2" TextWrapping="Wrap"
                               Text="Built-in shell verbs."
                               Foreground="{ThemeResource AppTextMuted}" FontSize="13"/>
                    <Border Grid.Row="3" BorderBrush="{ThemeResource AppBorder}" BorderThickness="0,1,0,0"
                            Padding="0,14,0,0" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="WindowsCount" FontSize="24" FontWeight="Medium"
                                       FontFamily="Consolas, Cascadia Code, monospace"
                                       Foreground="{ThemeResource AppAccent}"/>
                            <TextBlock Text="ENTRIES" FontFamily="Consolas, Cascadia Code, monospace"
                                       FontSize="11" Foreground="{ThemeResource AppTextDim}"
                                       VerticalAlignment="Center" CharacterSpacing="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>
