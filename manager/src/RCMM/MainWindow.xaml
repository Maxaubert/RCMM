<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="RCMM.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RCMM">
    <Grid x:Name="RootGrid" Background="{ThemeResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar: brand · nav · drag area · (window caption buttons) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/icon.png" Width="28" Height="28" VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource AppText}" Text="RCMM" CharacterSpacing="20"/>
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="1" Width="1" Height="22" Margin="14,0,14,0"
                    Background="{ThemeResource AppBorder}" VerticalAlignment="Center"/>

            <!-- Back / Home -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button x:Name="NavBackButton" Click="NavBack_Click"
                        Style="{StaticResource TitleBarIconButton}"
                        ToolTipService.ToolTip="Back" IsEnabled="False">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                </Button>
                <Button x:Name="NavHomeButton" Click="NavHome_Click"
                        Style="{StaticResource TitleBarIconButton}"
                        ToolTipService.ToolTip="Home" IsEnabled="False">
                    <FontIcon Glyph="&#xE80F;" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Drag area (rest of bar) + Settings on the right -->
            <Grid Grid.Column="3" Background="Transparent">
                <Button x:Name="SettingsButton" Click="Settings_Click"
                        Style="{StaticResource TitleBarIconButton}"
                        ToolTipService.ToolTip="Settings"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE713;" FontSize="15"/>
                </Button>
            </Grid>
        </Grid>

        <!-- Content -->
        <Frame x:Name="ContentFrame" Grid.Row="1"/>

        <!-- Footer (shows on list pages with Apply, invisible elsewhere) -->
        <Grid x:Name="FooterContainer" Grid.Row="2" Padding="48,12,48,16"
              BorderThickness="0">
            <Button x:Name="FooterApplyButton" Content="Apply"
                    Click="FooterApply_Click"
                    Style="{StaticResource AccentButton}" IsEnabled="False"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
